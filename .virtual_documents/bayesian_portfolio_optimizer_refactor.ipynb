# Helper: fetch adjusted close prices
def fetch_adjusted_close(tickers: dict, start: str, end: str) -> pd.DataFrame:
    data = yf.download(
        list(tickers.values()),
        start=start,
        end=end,
        auto_adjust=False,
        progress=False
    )
    df = data["Adj Close"].rename(columns={ticker: asset for asset, ticker in tickers.items()})
    return df.ffill()

